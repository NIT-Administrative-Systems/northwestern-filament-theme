{
    "private": true,
    "scripts": {
        "build:css": "node scripts/build-css.mjs",
        "build:css:check": "node scripts/build-css.mjs --check",
        "format": "prettier --write \"**/*.{blade.php,css,md,json,yml,xml}\"",
        "format:check": "prettier --check \"**/*.{blade.php,css,md,json,yml,xml}\"",
        "lint:css": "stylelint \"resources/css/**/*.css\"",
        "lint:css:fix": "stylelint \"resources/css/**/*.css\" --fix"
    },
    "devDependencies": {
        "@prettier/plugin-xml": "^3.4.2",
        "@shufo/prettier-plugin-blade": "^1.16.1",
        "consola": "^3.4.2",
        "lightningcss": "^1.32.0",
        "prettier": "^3.8.1",
        "prettier-plugin-packagejson": "^3.0.2",
        "stylelint": "^16.0.0",
        "stylelint-config-recess-order": "^7.7.0",
        "stylelint-config-standard": "^39.0.0",
        "stylelint-order": "^8.1.1"
    },
    "engines": {
        "node": ">= 24.0.0",
        "npm": "please-use-pnpm",
        "pnpm": ">= 10.0.0",
        "yarn": "please-use-pnpm"
    }
}
