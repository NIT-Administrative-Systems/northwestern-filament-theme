{
    "name": "northwestern-sysdev/filament-theme-demo",
    "description": "Minimal Filament app for visual regression testing",
    "type": "project",
    "private": true,
    "require": {
        "php": "^8.3",
        "filament/filament": "^4.0||^5.0",
        "laravel/framework": "^12.0||^13.0",
        "northwestern-sysdev/northwestern-filament-theme": "*"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
