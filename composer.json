{
    "name": "northwestern-sysdev/filament-theme",
    "description": "Northwestern University branded theme for Filament panels",
    "keywords": [
        "northwestern",
        "filament",
        "theme",
        "laravel"
    ],
    "homepage": "https://github.com/NIT-Administrative-Systems/filament-theme",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^11.0||^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.21",
        "orchestra/testbench": "^9.0||^10.0",
        "pestphp/pest": "^3.0",
        "rector/rector": "^2.0"
    },
    "scripts": {
        "format": "vendor/bin/pint",
        "rector": "vendor/bin/rector process --ansi",
        "rector:dry": "vendor/bin/rector process --dry-run --ansi",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=2G",
        "test": "vendor/bin/pest",
        "lint:css:fix": "pnpm lint:css:fix",
        "lint:css": "pnpm lint:css",
        "check": [
            "@rector",
            "@format",
            "@lint:css:fix",
            "@lint:css",
            "@analyse",
            "@test"
        ]
    },
    "autoload": {
        "psr-4": {
            "Northwestern\\FilamentTheme\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Northwestern\\FilamentTheme\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Northwestern\\FilamentTheme\\NorthwesternThemeServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
