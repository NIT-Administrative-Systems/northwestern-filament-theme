{
    "name": "northwestern-sysdev/northwestern-filament-theme",
    "description": "Northwestern University branded theme for Filament panels",
    "keywords": [
        "northwestern",
        "filament",
        "theme",
        "laravel"
    ],
    "homepage": "https://github.com/NIT-Administrative-Systems/northwestern-filament-theme",
    "license": "MIT",
    "type": "library",
    "support": {
        "issues": "https://github.com/NIT-Administrative-Systems/northwestern-filament-theme/issues",
        "source": "https://github.com/NIT-Administrative-Systems/northwestern-filament-theme"
    },
    "authors": [
        {
            "name": "Danny Foster",
            "email": "danny@northwestern.edu"
        }
    ],
    "require": {
        "php": "^8.3",
        "filament/filament": "^4.0||^5.0",
        "illuminate/contracts": "^12.0||^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.21",
        "orchestra/testbench": "^10.0||^11.0",
        "pestphp/pest": "^3.0||^4.0",
        "rector/rector": "^2.0"
    },
    "scripts": {
        "rector": "vendor/bin/rector process --ansi",
        "rector:dry": "vendor/bin/rector process --dry-run --ansi",
        "format": "vendor/bin/pint",
        "format:check": "vendor/bin/pint --test",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=2G",
        "test": "vendor/bin/pest",
        "check": [
            "@rector:dry",
            "@format:check",
            "pnpm format:check",
            "pnpm lint:css",
            "pnpm build:css:check",
            "@analyse",
            "@test"
        ],
        "fix": [
            "@rector",
            "@format",
            "pnpm format",
            "pnpm lint:css:fix",
            "pnpm build:css"
        ]
    },
    "autoload": {
        "psr-4": {
            "Northwestern\\FilamentTheme\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Northwestern\\FilamentTheme\\Tests\\": "tests/"
        }
    },
    "suggest": {
        "northwestern-sysdev/northwestern-laravel-ui": "Provides Northwestern brand lockup and office contact configuration automatically."
    },
    "extra": {
        "laravel": {
            "providers": [
                "Northwestern\\FilamentTheme\\NorthwesternThemeServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
